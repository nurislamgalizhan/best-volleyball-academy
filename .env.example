# ============================================================
# Best Volleyball Academy CRM — Environment Configuration
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env
# ============================================================

# === DOCKER ===
COMPOSE_PROJECT_NAME=best-volleyball-academy

# === БАЗА ДАННЫХ ===
DB_USER=bva
DB_PASSWORD=ЗАМЕНИТЕ_НА_НАДЁЖНЫЙ_ПАРОЛЬ
DB_NAME=best_volleyball_academy

# === BACKEND ===
# ОБЯЗАТЕЛЬНО: минимум 32 символа, случайная строка
# Сгенерировать: openssl rand -hex 32
JWT_SECRET=ЗАМЕНИТЕ_НА_СЛУЧАЙНУЮ_СТРОКУ_МИН_32_СИМВОЛА
JWT_EXPIRES_IN=7d
# URL фронтенда (для CORS). Укажите ваш домен:
FRONTEND_URL=https://ВАШ_ДОМЕН

# === ПЕРВЫЙ АДМИНИСТРАТОР ===
# Создаётся автоматически при первом запуске
ADMIN_PHONE=77700000000
ADMIN_PASSWORD=ваш_надёжный_пароль
ADMIN_FIRST_NAME=Администратор
ADMIN_LAST_NAME=Системы

# === Green API (WhatsApp коды) ===
GREEN_API_URL=https://api.green-api.com
GREEN_API_ID_INSTANCE=ВАШ_ID_INSTANCE
GREEN_API_TOKEN_INSTANCE=ВАШ_API_TOKEN_INSTANCE

# === ПОРТЫ ===
# Для второго сайта на одном сервере не занимайте 80/443 напрямую.
# Внешний nginx должен прокидывать домен на http://127.0.0.1:8081
APP_HOST=127.0.0.1
APP_PORT=8081
