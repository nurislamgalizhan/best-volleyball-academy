generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  VISITOR
}

enum AdminActionType {
  USER_CREATED
  VISITS_BALANCE_UPDATED
  TARIFF_SOLD
  SALE_UPDATED
  SALE_REFUNDED
  USER_DEACTIVATED
  ADMIN_VISIT_CHECKIN
  SUBSCRIPTION_FROZEN
  SUBSCRIPTION_CANCELLED
}

enum TimeType {
  ANY
  MORNING
  EVENING
}

enum PaymentMethod {
  CASH
  KASPI
  HALYK
  MIXED
}

enum CardProvider {
  KASPI
  HALYK
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  REFUNDED
  CANCELLED
}

enum SaleStatus {
  ACTIVE
  REFUNDED
}

model User {
  id              Int       @id @default(autoincrement())
  firstName       String
  lastName        String
  phone           String    @unique
  passwordHash    String
  role            Role      @default(VISITOR)
  visitsBalance   Int       @default(0)
  subscriptionEnd DateTime?
  isVerified      Boolean   @default(false)
  isActive        Boolean   @default(true)
  frozenUntil     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  visitLogs VisitLog[]
  saleLogs  SaleLog[]
  subscriptions UserSubscription[]
  adminActions      AdminActionLog[] @relation("AdminActor")
  targetAdminActions AdminActionLog[] @relation("AdminTarget")

  verificationCode        String?
  verificationCodeExpires DateTime?

  @@map("users")
}

model Section {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tariffs       Tariff[]
  saleLogs      SaleLog[]
  visitLogs     VisitLog[]
  subscriptions UserSubscription[]

  @@map("sections")
}

model Tariff {
  id           Int      @id @default(autoincrement())
  sectionId    Int
  name         String
  visitsAmount Int?
  durationDays Int
  price        Int
  isActive     Boolean  @default(true)
  timeType     TimeType @default(ANY)
  timeStart    String?
  timeEnd      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  saleLogs SaleLog[]
  subscriptions UserSubscription[]
  section  Section @relation(fields: [sectionId], references: [id])

  @@index([sectionId, isActive])
  @@map("tariffs")
}

model VisitLog {
  id             Int      @id @default(autoincrement())
  userId         Int
  sectionId      Int
  userSubscriptionId Int?
  visitsDeducted Int
  guestCount     Int      @default(0)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])
  userSubscription UserSubscription? @relation(fields: [userSubscriptionId], references: [id])

  @@index([sectionId, createdAt])
  @@index([userSubscriptionId])
  @@map("visit_logs")
}

model SaleLog {
  id            Int            @id @default(autoincrement())
  userId        Int
  sectionId     Int
  tariffId      Int
  pricePaid     Int
  paymentMethod PaymentMethod  @default(CASH)
  cashAmount    Int            @default(0)
  cardAmount    Int            @default(0)
  cardProvider  CardProvider?
  status        SaleStatus     @default(ACTIVE)
  refundAmount  Int            @default(0)
  refundedAt    DateTime?
  editedAt      DateTime?
  createdAt     DateTime       @default(now())

  user   User    @relation(fields: [userId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])
  tariff Tariff   @relation(fields: [tariffId], references: [id])
  subscription UserSubscription?

  @@index([sectionId, createdAt])
  @@index([status])
  @@map("sale_logs")
}

model UserSubscription {
  id              Int                @id @default(autoincrement())
  userId          Int
  sectionId       Int
  tariffId        Int
  saleLogId       Int?               @unique
  visitsBalance   Int                @default(0)
  subscriptionEnd DateTime
  frozenUntil     DateTime?
  status          SubscriptionStatus @default(ACTIVE)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  section   Section   @relation(fields: [sectionId], references: [id])
  tariff    Tariff    @relation(fields: [tariffId], references: [id])
  saleLog   SaleLog?  @relation(fields: [saleLogId], references: [id])
  visitLogs VisitLog[]

  @@index([userId, status])
  @@index([sectionId, status])
  @@index([subscriptionEnd, status])
  @@map("user_subscriptions")
}

model RegistrationAttempt {
  id                      Int       @id @default(autoincrement())
  phone                   String    @unique
  passwordHash            String
  firstName               String
  lastName                String
  verificationCode        String?
  verificationCodeExpires DateTime?
  createdAt               DateTime  @default(now())

  @@map("registration_attempts")
}

model AdminActionLog {
  id           Int             @id @default(autoincrement())
  adminId      Int
  targetUserId Int?
  action       AdminActionType
  details      Json?
  createdAt    DateTime        @default(now())

  admin      User  @relation("AdminActor", fields: [adminId], references: [id])
  targetUser User? @relation("AdminTarget", fields: [targetUserId], references: [id])

  @@index([adminId, createdAt])
  @@index([targetUserId, createdAt])
  @@map("admin_action_logs")
}
